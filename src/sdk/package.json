{
  "name": "@attention-app/sdk",
  "version": "1.0.0",
  "description": "Attention Safety SDK — Drop-in security layer for any mobile or web app. Provides SOS, incident alerts, geofencing, chain messaging, location sharing, and real-time safety scoring.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "module": "dist/index.mjs",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./web": {
      "import": "./dist/web-embed.mjs",
      "require": "./dist/web-embed.js",
      "types": "./dist/web-embed.d.ts"
    }
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.sdk.json",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "safety",
    "security",
    "sos",
    "geofencing",
    "incidents",
    "location-sharing",
    "react-native",
    "sdk",
    "attention",
    "community-safety"
  ],
  "author": "Attention App",
  "license": "MIT",
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-native": ">=0.70.0"
  },
  "peerDependenciesMeta": {
    "react-native": {
      "optional": true
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sae3ovr/attention-app.git"
  }
}
